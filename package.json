{
  "name": "cstl-control-tower",
  "version": "1.0.0",
  "private": true,
  "description": "Phoenix Tanner — CSTL booking & documentation control tower",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && prisma db push --skip-generate && next build",
