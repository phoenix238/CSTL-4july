generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// One record per client — the app's index. The client's Drive folder + Google Doc
// (pointed at by driveFolderId / docId) remain the system of record for notes.
model Client {
  id            String        @id @default(cuid())
  name          String
  email         String        @default("")
  phone         String        @default("")
  clinic        String        @default("waterloo") // preferred clinic: waterloo | bethnal
  marketing     Boolean       @default(false)
  intakeDone    Boolean       @default(false)
  welcomeSent   Boolean       @default(false) // access note + intake link go in the FIRST email only
  dob           String        @default("")
  occupation    String        @default("")
  doctor        String        @default("")
  meds          String        @default("")
  conditions    String        @default("")
  emergency     String        @default("")
  referred      String        @default("")
  driveFolderId String        @default("")
  docId         String        @default("")
  intakeToken   String        @default("") // private token for the client's in-app intake link
  intakeEmailSentAt DateTime? // last time the intake-form email was sent
  reviewEmailSentAt DateTime? // last time the post-session review email was sent
  consentGiven  Boolean? // null = not yet answered; set from the intake form's Yes/No consent question
  // Present in the shared production DB from the intake-auto-share feature on
  // another branch (client-message-intake-workflow) — not wired into any code
  // here. Declared so `prisma db push` never proposes dropping this real data.
  calendarInviteSharedAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bookings      Booking[]
  notes         SessionNote[]
  recordings    SessionRecording[]
  enquiries     Enquiry[]

  @@index([name])
  @@index([email])
  @@index([intakeToken])
}

// Cached copy of a session note for instant profile views;
// the authoritative copy is appended to the client's Google Doc on save.
model SessionNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date      DateTime
  clinic    String
  raw       String
  bullets   String[]
  createdAt DateTime @default(now())

  @@index([clientId, date])
}

// A live Clean Language session captured in the Session tab. The full verbatim
// transcript lives here (the app is where you glance back at exact words); a
// curated summary + pinned phrases + notes are also appended to the client's Doc.
model SessionRecording {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  date       DateTime
  clinic     String
  transcript String   // full live transcript, verbatim
  pinned     String[] // the client's highlight moments (their words)
  myNotes    String   @default("") // therapist's own notes taken during the session
  bullets    String[] // Claude-generated summary bullets
  createdAt  DateTime @default(now())

  @@index([clientId, date])
}

model Booking {
  id               String   @id @default(cuid())
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  startsAt         DateTime // start of the 60-min session
  clinic           String // waterloo | bethnal
  status           String   @default("confirmed") // confirmed | cancelled | done
  personalEventId  String   @default("") // "(Client) — Clinic" on the personal calendar
  secondaryEventId String   @default("") // Waterloo: "R5 - Phoenix" room event · Bethnal: 2h "Phoenix" Chalk Farm block
  emailSent        Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([startsAt])
  @@index([clientId])
}

model Enquiry {
  id        String   @id @default(cuid())
  via       String   @default("PASTED") // WHATSAPP | EMAIL | PASTED
  name      String   @default("")
  text      String
  status       String     @default("waiting") // waiting | offered | booked | booked_online | dismissed
  clientId     String? // set once the enquiry is saved as / matched to a client
  client       Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clinic       String     @default("") // which clinic the offered times are for
  offeredTimes DateTime[] // slots offered to the client (offer mode), awaiting their pick
  offerToken   String     @default("") // private token for the client's self-book link
  createdAt    DateTime   @default(now())
  // Set when the enquiry came in via the Gmail add-on — so booking/offer replies
  // land back in the client's original Gmail thread instead of a fresh email.
  gmailThreadId  String   @default("") // Gmail thread id of the client's email
  gmailMessageId String   @default("") // RFC Message-ID, for In-Reply-To/References

  @@index([clientId])
  @@index([offerToken])
}

// Single row (id = 1). Holds editable settings and the Google wiring.
model AppSettings {
  id                    Int    @id @default(1)
  accessNote            String @default("My treatment space has no step-free access at both locations — there are stairs. Please let me know if mobility or accessibility is a concern and I will do my best to accommodate your needs.")
  emailTemplateWaterloo String @default("Hi {name},\n\nLooking forward to seeing you at Waterloo. Sessions are £80 for 60 minutes, payable on the day by card or bank transfer.\n\nA few notes before we meet:\n{accessNote}\n\nPlease fill out the short intake form when you get a moment — the link is below.\n\nSee you soon,\nPhoenix")
  emailTemplateBethnal  String @default("Hi {name},\n\nLooking forward to seeing you at Bethnal Green. Sessions are on a £30–60 sliding scale for 60 minutes — pay what feels fair on the day.\n\nA few notes before we meet:\n{accessNote}\n\nPlease fill out the short intake form when you get a moment — the link is below.\n\nSee you soon,\nPhoenix")
  paymentDetails        String @default("Payment on the day by card or bank transfer. Bank details: (add yours in Settings).")
  waterlooAddress       String @default("") // full address — calendar invite location + Maps link in the first email
  bethnalAddress        String @default("") // full address — calendar invite location + Maps link in the first email
  // Short "about this clinic" note shown on the public booking page under the
  // address — parking, what to expect, how to find the door, etc.
  waterlooArrivalNote   String @default("")
  bethnalArrivalNote    String @default("")
  intakeFormUrl         String @default("https://forms.gle/2nPTLzHcffgzmydo8")
  googleRefreshToken    String @default("")
  personalCalendarId    String @default("primary")
  roomCalendarId        String @default("") // R5 room calendar
  chalkFarmCalendarId   String @default("") // Bethnal Green 2h blocks
  clientsFolderId       String @default("") // Drive › CSTL › Clients
  reflectionsDocId      String @default("") // Drive › CSTL › "Phoenix session reflections" — one Doc, all clients
  marketingSheetId      String @default("") // spreadsheet at Drive › CSTL › Clients › Docs
  appUrl                String @default("") // base URL for building intake / share links
  intakeQuestions       Json? // configurable intake questions; null = built-in defaults
  clientCopy            Json? // editable client-facing message overrides; null/missing keys = built-in defaults (see lib/clientCopy.ts)
  // Legacy single review-email fields — superseded by the per-clinic ones below
  // (kept in place rather than dropped, so `prisma db push` never has to touch existing data).
  mapsReviewUrl         String @default("") // Google Maps "leave a review" link
  reviewEmailSubject    String @default("How was your session?")
  reviewEmailBody       String @default("Hi {name},\n\nIt was lovely to see you. I really hope your session landed well.\n\nIf you have a moment, a short Google review means the world to a small practice like mine:\n{mapsUrl}\n\nAnd if you'd like the occasional email about offers and clinic news, you can opt in here (one tap, no obligation):\n{optInLink}\n\nWarm wishes,\nPhoenix")
  // Post-session review email, one per clinic — each clinic has its own Google Business review link.
  mapsReviewUrlWaterloo    String @default("") // Google Maps "leave a review" link — Waterloo
  mapsReviewUrlBethnal     String @default("") // Google Maps "leave a review" link — Bethnal Green
  reviewEmailSubjectWaterloo String @default("How was your session?")
  reviewEmailSubjectBethnal  String @default("How was your session?")
  reviewEmailBodyWaterloo  String @default("Hi {name},\n\nIt was lovely to see you. I really hope your session landed well.\n\nIf you have a moment, a short Google review means the world to a small practice like mine:\n{mapsUrl}\n\nAnd if you'd like the occasional email about offers and clinic news, you can opt in here (one tap, no obligation):\n{optInLink}\n\nWarm wishes,\nPhoenix")
  reviewEmailBodyBethnal   String @default("Hi {name},\n\nIt was lovely to see you. I really hope your session landed well.\n\nIf you have a moment, a short Google review means the world to a small practice like mine:\n{mapsUrl}\n\nAnd if you'd like the occasional email about offers and clinic news, you can opt in here (one tap, no obligation):\n{optInLink}\n\nWarm wishes,\nPhoenix")

  // Public self-booking (/book) — recurring weekly hours per clinic; null/empty = nothing
  // bookable yet, until configured in Settings › Availability. Shape: WeeklyHours in
  // src/lib/booking/availability.ts.
  weeklyHours          Json?
  // Tunable booking parameters — the Settings "switchboard" sliders.
  bookingSlotMinutes   Int @default(30)  // candidate slot spacing
  bookingMinNoticeMins Int @default(120) // can't book within this many minutes of now
  bookingHorizonDays   Int @default(21)  // how many days ahead the public page shows/allows
  bookingBufferMinutes Int @default(0)   // extra padding either side of every session's footprint
  chalkFarmBufferMinutes Int @default(30) // safety gap around a studio-mate's booking on the shared Chalk Farm calendar (Bethnal Green)
  bookingNotifyEmail   Boolean @default(true) // email Phoenix when someone books via /book
}

// The single shared "Phoenix" room block on the Chalk Farm calendar for one day.
// Bethnal Green sessions nest inside it; the block auto-grows/shrinks to span the
// day's sessions, so clients can sit as close as the schedule allows (not 2h apart).
model ChalkFarmDayBlock {
  date      String   @id // "YYYY-MM-DD" London calendar date
  eventId   String // the Google event id of that day's shared block
  updatedAt DateTime @updatedAt
}

// One-off availability exceptions — either opens an extra date/window beyond the
// recurring weekly hours, or blocks/closes a normally-open one (holidays etc.).
model AvailabilityOverride {
  id        String   @id @default(cuid())
  clinic    String   // waterloo | bethnal
  date      String   // "YYYY-MM-DD", London calendar date — plain string avoids DST/UTC edge cases
  kind      String   // "open" | "block"
  startMin  Int      // minutes after London midnight
  endMin    Int      // minutes after London midnight
  note      String   @default("")
  createdAt DateTime @default(now())

  @@index([clinic, date])
}
